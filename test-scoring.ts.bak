
import { calculateCVScore, cvData, jobData } from './services/cv-scorer.ts';

const mockCV: cvData = {
    experience: [{}, {}, {}], // Equivalent to 3 items -> 3 years in my simple logic
    skills: ['React', 'Node.js', 'TypeScript', 'AWS'],
    education: { degree: 'Bachelor' },
    projects: [{}, {}],
    otherInfo: ['Teamwork', 'English']
};

const mockJob: jobData = {
    requirements: {
        experience: 3, // Requires 3 years
        techStack: ['React', 'Node.js', 'Typescript'], // Note case difference for testing
        education: 'Bachelor',
        softSkills: ['Teamwork', 'Communication']
    },
    description: 'A great job'
};

const result = calculateCVScore(mockCV, mockJob);
console.log('Overall Score:', result.overallScore);
console.log('Details:', JSON.stringify(result.details, null, 2));

// Expected:
// Experience: 3 items vs 3 years -> 100% * 0.4 = 40
// Tech: 3/3 match (normalized) -> 100% * 0.3 = 30
// Edu: 80% (default) * 0.1 = 8
// Proj: 70% (default) * 0.1 = 7
// Soft: 1/2 match (Teamwork) -> 50% * 0.1 = 5
// Total: 40 + 30 + 8 + 7 + 5 = 90
