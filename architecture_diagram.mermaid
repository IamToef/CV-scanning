graph TD
    %% Custom Styles (sleek, professional color palette)
    classDef user fill:#f8fafc,stroke:#64748b,stroke-width:2px,color:#334155;
    classDef vercel fill:#f3e8ff,stroke:#7c3aed,stroke-width:2px,color:#6d28d9;
    classDef docker fill:#fef3c7,stroke:#d97706,stroke-width:2px,color:#b45309;
    classDef qdrant fill:#dcfce7,stroke:#16a34a,stroke-width:2px,color:#15803d;
    classDef gemini fill:#fce7f3,stroke:#db2777,stroke-width:2px,color:#be185d;
    classDef client fill:#e0f2fe,stroke:#0284c7,stroke-width:2px,color:#0369a1;

    %% Components
    Recruiter(["🧑‍💼 Recruiter / HR Manager"]):::user

    subgraph Vercel_Cloud ["☁️ Vercel Cloud"]
        App["💻 recruitPRO UI (Next.js)"]:::vercel
    end

    subgraph Docker_Host ["🐳 Docker Self-Hosted Server"]
        n8n["⚙️ n8n Automation Engine"]:::docker
        Qdrant[("🗄️ Qdrant Vector DB")]:::qdrant
    end

    subgraph External_APIs ["✨ External Cloud APIs"]
        Gemini["🤖 Gemini API (LLM & Embeddings)"]:::gemini
    end

    Excel["📊 Excel Report"]:::client

    %% Data Flow
    Recruiter -->|"Upload CV & JD / Chat"| App
    App -->|"API Request (Score & Chat)"| n8n
    
    %% n8n Orchestration
    n8n <-->|"JSON Parser & Embeddings"| Gemini
    n8n <-->|"Semantic Vector Search"| Qdrant
    
    n8n -.->|"Webhook Response"| App
    App -->|"Export Data"| Excel

